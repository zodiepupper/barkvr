[sub_resource type="GDScript" id="GDScript_dw37y"]
script/source = "extends AnimationPlayer

@onready var mesh_instance_3d_2: MeshInstance3D = $\"..\"

func _ready() -> void:
	mesh_instance_3d_2.get_active_material(0).albedo_texture.noise.seed = randi()
	create_tween().tween_property(mesh_instance_3d_2.get_active_material(0),\\
		\"albedo_color\",\\
		Color(randf_range(.1,.4),randf_range(.1,.4),randf_range(.1,.4)),\\
		2)
	play(\"launch\")

func _process(delta: float) -> void:
	get_parent().global_position = get_viewport().get_camera_3d().global_position
"

