[sub_resource type="GDScript" id="GDScript_mkksm"]
script/source = "extends Node

func onclick():
	get_tree().get_first_node_in_group(\"player\").scale *= 1.1
"

[sub_resource type="GDScript" id="GDScript_apv3r"]
script/source = "extends Node

func onclick():
	get_tree().get_first_node_in_group(\"player\").scale *= .9
"

[sub_resource type="GDScript" id="GDScript_3v3kl"]
script/source = "extends Node

func onclick():
	var new_state = !get_tree().get_first_node_in_group(\"player\").flymode
	get_tree().get_first_node_in_group(\"player\").noclip = new_state
	get_tree().get_first_node_in_group(\"player\").flymode = new_state
"

[sub_resource type="GDScript" id="GDScript_ft12v"]
script/source = "extends Node3D

func onclick():
	get_tree().get_first_node_in_group(\"localuinode\").reveal(true)
	var localui = get_tree().get_first_node_in_group(\"localuipanel\")
	localui.global_position = global_position
	if localui and localui is Node3D:
		localui.look_at(to_global(Vector3(0,.1,0)), Vector3.UP, true)
"

[sub_resource type="GDScript" id="GDScript_djyhs"]
script/source = "extends Node

func onclick():
	var player = get_tree().get_first_node_in_group(\"player\")
	if player and \"delete_held\" in player:
		get_tree().get_first_node_in_group(\"player\").delete_held()
"

[sub_resource type="GDScript" id="GDScript_wrd3g"]
script/source = "extends Node

func onclick():
	Engine.get_singleton(\"event_manager\").undo_action()
"

[sub_resource type="GDScript" id="GDScript_tka4v"]
script/source = "extends Object

func onclick():
	LocalGlobals.clear_gizmos_func()
"

